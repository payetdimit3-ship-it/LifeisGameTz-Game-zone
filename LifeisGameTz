        function generateNewPin() {
    const pin = Math.floor(100000 + Math.random() * 900000).toString();

    // chagua type
    const type = prompt("Type ya PIN? (cheap / premium)");

    let maxUse = 10;

    if (type && type.toLowerCase() === "premium") {
        maxUse = 20;
    }

    PINS.push({
        code: pin,
        used: 0,
        max: maxUse,
        type: type ? type.toUpperCase() : "CHEAP"
    });

    localStorage.setItem("pins", JSON.stringify(PINS));

    loadPins();
    alert(`PIN mpya (${type}): ${pin}`);
}

