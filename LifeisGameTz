        // ===== SALAM =====
        if (lower.includes("habari") || lower.includes("hello")) {
            reply = "Nipo kaka 🔥 niambie unataka kufanya nini?";
        }

        // ===== ONGEZA GAME =====
        else if (lower.includes("ongeza game")) {
            const name = prompt("Jina la game:");
            const price = prompt("Bei:");
            const cat = prompt("Category (Mobile/PC/Tools):");
            const img = prompt("Image URL:");
            const link = prompt("Download Link:");

            if (name && price && cat && img && link) {
                games.push({
                    name,
                    price: price === "FREE" ? "FREE" : parseInt(price),
                    cat,
                    img,
                    link
                });

                renderStore('all');
                reply = `✅ Game "${name}" imeongezwa kikamilifu!`;
            } else {
                reply = "❌ Umeacha baadhi ya taarifa.";
            }
        }

        // ===== GENERATE PIN =====
        else if (lower.includes("pin mpya") || lower.includes("generate pin")) {
            const pin = Math.floor(100000 + Math.random() * 900000).toString();

            PINS.push({
    code: pin,
    used: 0,
    max: 10,
    type: "CHEAP"
});
            loadPins();
            reply = `🔑 PIN mpya: ${pin}`;
        }

        // ===== ONYESHA GAMES =====
        else if (lower.includes("games") || lower.includes("orodha")) {
            reply = `🎮 Una games ${games.length} kwenye store yako.`;
        }

        // ===== ONYESHA PINS =====
        else if (lower.includes("onyesha pin")) {
            reply = PINS.map(p => `🔑 ${p.code} (${p.downloads}/${p.maxDownloads})`).join("<br>");
        }

        // ===== BADILISHA BEI =====
        else if (lower.includes("badilisha bei")) {
            const name = prompt("Andika jina la game:");
            const game = games.find(g => g.name.toLowerCase().includes(name.toLowerCase()));

            if (game) {
                const newPrice = prompt("Bei mpya:");
                game.price = newPrice === "FREE" ? "FREE" : parseInt(newPrice);
                renderStore('all');
                reply = `✅ Bei ya ${game.name} imebadilika!`;
            } else {
                reply = "❌ Game haijapatikana.";
            }
        }

        // ===== DEFAULT =====
        chat.innerHTML += `<div class="bg-gray-800 p-4 rounded-2xl mr-auto max-w-[85%]">${reply}</div>`;
        chat.scrollTop = chat.scrollHeight;

    }, 600);
}

function addStore() {
    const name = document.getElementById('sName').value.trim();
    const price = document.getElementById('sPrice').value.trim();
    const img = document.getElementById('sImg').value.trim();
    const contact = document.getElementById('sLink').value.trim();

    if (!name || !price || !img || !contact) {
        alert("⚠️ Tafadhali jaza taarifa zote!");
        return;
    }

    storeItems.push({
        name: name,
        price: price,
        img: img,
        contact: contact   // Badilisha hapa kuwa "contact"
    });

    localStorage.setItem("storeItems", JSON.stringify(storeItems));
    loadStoreAdmin();

    // Clear fields
    document.getElementById('sName').value = "";
    document.getElementById('sPrice').value = "";
    document.getElementById('sImg').value = "";
    document.getElementById('sLink').value = "";

    alert("✅ Bidhaa imeongezwa kikamilifu!");
}

function loadStoreAdmin() {
    const box = document.getElementById("storeAdminList");
    box.innerHTML = "";

    storeItems.forEach((item, i) => {
        box.innerHTML += `
        <div class="bg-black p-3 rounded flex justify-between items-center">
            <div>
                <b>${item.name}</b><br>
                <small>${item.price} TZS</small>
            </div>
            <button onclick="deleteStore(${i})" class="bg-red-600 px-3 py-1 rounded text-xs">
                Futa
            </button>
        </div>`;
    });
}

function deleteStore(i) {
    if (confirm("Una uhakika wa kufuta?")) {
        storeItems.splice(i, 1);
        localStorage.setItem("storeItems", JSON.stringify(storeItems));
        loadStoreAdmin();
    }
}

function renderStoreItems() {
    const grid = document.getElementById('gamesGrid');
    const title = document.getElementById('catTitle');

    title.innerText = "STORE YA BIASHARA";
    grid.innerHTML = "";

    // Hakuna bidhaa
    if (storeItems.length === 0) {
        grid.innerHTML = `
            <div class="col-span-full text-center text-gray-500">
                Hakuna bidhaa bado...
            </div>
        `;
        return;
    }

    // Display bidhaa
    storeItems.forEach(item => {
        grid.innerHTML += `
            <div class="game-card">
                <img src="${item.img}" class="w-full aspect-[3/4] object-cover">

                <div class="p-3">
                    <h3 class="text-[10px] font-bold uppercase truncate mb-2">
                        ${item.name}
                    </h3>

                    <div class="flex justify-between items-center">
                        <span class="text-yellow-400 font-black text-[10px]">
                            ${item.price} TZS
                        </span>

                        <a href="${item.link}" target="_blank"
                        class="bg-green-500 text-black px-3 py-1 rounded font-black text-[8px] uppercase hover:bg-green-600 transition">
                            Wasiliana
                        </a>
                    </div>
                </div>
            </div>
        `;
    });

    toggleMenu();
}

        // ====================== INIT ======================
        window.addEventListener('load', () => {
    updateHero();
    renderStore('all');
});
    </script>
