        function verifyPin() {
    const input = document.getElementById('pinInput').value.trim();

    const pinIndex = PINS.findIndex(p => p.code === input);

    if (pinIndex === -1) {
        alert("❌ Password sio sahihi!");
        return;
    }

    const pin = PINS[pinIndex];

    if ((pin.used || 0) >= (pin.max || 0)) {
        alert(`⚠️ PIN ya ${pin.type} imeshaisha matumizi!`);
        return;
    }

    pin.used += 1;

    localStorage.setItem("pins", JSON.stringify(PINS));

    alert(`✅ ${pin.type} PIN OK (${pin.used}/${pin.max})`);

    window.open(activeLink, "_blank");
}
